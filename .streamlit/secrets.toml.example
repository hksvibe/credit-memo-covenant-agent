# Streamlit secrets template.
# Copy to .streamlit/secrets.toml for local dev, OR paste into
# Streamlit Community Cloud "Secrets" when deploying.
#
# On the cloud, these become available at st.secrets["..."] AND are
# promoted to os.environ by src/app.py so review.py picks them up.

ANTHROPIC_API_KEY = "sk-ant-api03-..."

# Optional. If set, users must enter this password to use the app.
# Leave blank / delete the line to run the app un-gated.
APP_PASSWORD = "change-me"
